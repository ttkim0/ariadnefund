# ============================================================
# Large source data (regenerable from public NOAA / Kalshi APIs)
# ============================================================
# These are too big for git (>100MB GitHub hard limit).
# Re-download via:
#   * NOAA LCD:   https://www.ncei.noaa.gov/cdo-web/  (request product=LCD, station=USW00023234)
#   * NOAA ISD:   https://www.ncei.noaa.gov/products/land-based-station/integrated-surface-database
LCD datas.csv
global hourly.csv

# Large derived parquet (regenerable in ~2 min via code/03_features.py)
data/sfo_features.parquet
data/sfo_targets.parquet
data/test_predictions.parquet
data/decision_dataset.parquet
data/decision_dataset_v2.parquet
data/decision_dataset_v2_meta.parquet
data/kalshi_candles.parquet

